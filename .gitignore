# ============================================================
# DocFlow AI - Root .gitignore
# ============================================================

# --- Private / internal folders (do NOT share to git) ---
.ai/
docs/

# --- Dependencies ---
node_modules/

# --- Environment / secrets ---
.env
.env.local
.env.*.local

# --- Build output ---
dist/
build/
coverage/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
