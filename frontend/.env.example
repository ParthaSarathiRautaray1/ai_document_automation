# DocFlow AI - Frontend environment
# Copy to `.env` (or `.env.local`) for local development.

# Base URL of the backend API (includes the /api/v1 prefix).
# NOTE: Vite inlines VITE_* variables at BUILD time. In a container this is a
# build argument (see frontend/Dockerfile), not a runtime env var — changing it
# requires rebuilding the image. It must be the URL the BROWSER can reach, not a
# compose-internal hostname.
VITE_API_URL=http://localhost:5000/api/v1
