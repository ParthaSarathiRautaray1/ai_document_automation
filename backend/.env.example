# ============================================================
# DocFlow AI - Backend Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
# The frontend origin. Used for CORS and for links in outbound email.
# In production this MUST NOT be localhost (the startup guard refuses to boot).
CLIENT_URL=http://localhost:5173

# Extra allowed browser origins beyond CLIENT_URL (comma-separated).
# e.g. CORS_ORIGINS=https://www.docflow.example,https://staging.docflow.example
CORS_ORIGINS=

# Proxy hops in front of the API (Nginx/CDN/load balancer). 0 = direct.
# Trusting more hops than exist lets a client spoof its IP past the rate limiter.
TRUST_PROXY=1

# Max request body size, and how long shutdown waits for in-flight requests.
JSON_BODY_LIMIT=1mb
SHUTDOWN_TIMEOUT_MS=10000

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/docflow_ai

# Reconcile model indexes with the DB on boot. Keep this ON in production:
# `autoIndex` is disabled there, so this is the ONLY thing that creates the
# unique/partial indexes the data model depends on.
DB_SYNC_INDEXES=true

# Only set this if your host's DNS cannot resolve `mongodb+srv://` SRV records
# (a known Windows/corporate-DNS issue). Leave EMPTY in a cloud/VPC deployment —
# forcing public resolvers there breaks private-zone DNS.
# e.g. DB_SRV_DNS_SERVERS=8.8.8.8,1.1.1.1
DB_SRV_DNS_SERVERS=

# --- JWT (Authentication) ---
# Use long, random strings. Generate with:  openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Password reset token lifetime (minutes)
RESET_TOKEN_EXPIRES_MIN=15

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# --- Email (Brevo) --- (used from Module 1 Task 4: password reset)
# Leave BREVO_API_KEY empty in dev/test: sends are SKIPPED (recorded as `skipped`
# in the email log) and reset/invite links are written to the log instead.
# To actually deliver email you need BOTH:
#   1. BREVO_API_KEY      — Brevo dashboard → SMTP & API → API Keys
#   2. EMAIL_FROM_ADDRESS — a sender/domain VERIFIED in Brevo. The default below
#      is a placeholder domain and Brevo will reject sends from it.
BREVO_API_KEY=
EMAIL_FROM_NAME=DocFlow AI
EMAIL_FROM_ADDRESS=no-reply@docflow.ai

# --- Storage (Cloudinary) --- (used from later modules)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- AI (OpenRouter) --- (used from Module 16)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- PDF engine (Puppeteer) ---
# Path to a system Chromium. Set in containers that install the browser via the
# OS package manager (the Dockerfile sets /usr/bin/chromium). Leave empty locally
# to use Puppeteer's own bundled binary.
PUPPETEER_EXECUTABLE_PATH=

# --- TLS ---
# Set true once HTTPS terminates in front of the API. Marks the refresh cookie
# `secure` and enables HSTS.
IS_HTTPS=false
