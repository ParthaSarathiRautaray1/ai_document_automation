# ============================================================
# DocFlow AI - Backend Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/docflow_ai

# --- JWT (Authentication) ---
# Use long, random strings. Generate with:  openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Password reset token lifetime (minutes)
RESET_TOKEN_EXPIRES_MIN=15

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# --- Email (Brevo) --- (used from Module 1 Task 4: password reset)
# Leave BREVO_API_KEY empty in dev/test: sends are skipped and the reset link
# is written to the log instead. Set it in production to actually deliver email.
BREVO_API_KEY=
EMAIL_FROM_NAME=DocFlow AI
EMAIL_FROM_ADDRESS=no-reply@docflow.ai

# --- Storage (Cloudinary) --- (used from later modules)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- AI (OpenRouter) --- (used from Module 16)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
